{
  "expo": {
    "name": "CloneGuard",
    "slug": "CloneGuard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "cloneguard",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.m-gulfam.CloneGuard"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.m_gulfam.CloneGuard",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera",
          "barcodeScannerEnabled": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#053348",
          "image": "./assets/images/splash-icon.png",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#053348"
          },
          "imageWidth": 200
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Sora-Bold.ttf",
            "./assets/fonts/Sora-SemiBold.ttf",
            "./assets/fonts/Teachers-Bold.ttf",
            "./assets/fonts/Teachers-BoldItalic.ttf",
            "./assets/fonts/Teachers-ExtraBold.ttf",
            "./assets/fonts/Teachers-ExtraBoldItalic.ttf",
            "./assets/fonts/Teachers-Italic.ttf",
            "./assets/fonts/Teachers-Medium.ttf",
            "./assets/fonts/Teachers-MediumItalic.ttf",
            "./assets/fonts/Teachers-Regular.ttf",
            "./assets/fonts/Teachers-SemiBold.ttf",
            "./assets/fonts/Teachers-SemiBoldItalic.ttf"
          ]
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
